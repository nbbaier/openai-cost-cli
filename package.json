{
	"name": "openai-cost-cli",
	"version": "1.0.0",
	"description": "CLI tool for tracking OpenAI organization costs and token usage",
	"type": "module",
	"bin": {
		"openai-cost": "src/index.ts"
	},
	"scripts": {
		"start": "bun src/index.ts",
		"cost": "bun src/index.ts",
		"tokens": "bun src/token-usage.ts",
		"token-costs": "bun src/token-costs.ts",
		"update-prices": "bun src/utils/update-prices.ts",
		"lint": "bunx biome check .",
		"format": "bunx biome format . --write",
		"lint:fix": "bunx biome check . --write",
		"typecheck": "tsgo --noEmit"
	},
	"keywords": [
		"openai",
		"cost",
		"cli",
		"usage",
		"tokens",
		"monitoring"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260328.1"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@better-fetch/fetch": "^1.1.21",
		"temporal-polyfill": "^0.3.2",
		"zod": "^4.3.6"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"module": "src/index.ts",
	"private": true
}
